# WishesU / Prankwish Cloudflare Worker Configuration
#
# 1) Copy this file to `wrangler.toml`
# 2) Update the values marked "CHANGE ME"
# 3) Create D1 + R2 resources (commands in DEPLOY.md)
# 4) Set secrets via `wrangler secret put ...`

name = "CHANGE-ME-worker-name"
main = "src/index.js"
compatibility_date = "2024-01-01"
workers_dev = true

# Optional: bind static assets (recommended)
[assets]
directory = "./public"
binding = "ASSETS"

# IMPORTANT: Only run the Worker for dynamic routes.
# Everything else is served directly as static assets (cheaper + faster).
run_worker_first = [
  "/",               # Homepage (can be dynamic)
  "/api/*",          # All API routes
  "/blog*",          # Blog archive + dynamic post pages
  "/forum*",         # Forum pages
  "/admin/*",        # Admin routes
  "/product*",       # Product pages
  "/download/*",     # Secure downloads
  "/robots.txt",     # Dynamic robots.txt
  "/sitemap.xml"     # Dynamic sitemap.xml
]

not_found_handling = "404-page"

# Optional: Custom domain routes
# routes = [
#   { pattern = "CHANGE-ME.com", custom_domain = true },
#   { pattern = "www.CHANGE-ME.com", custom_domain = true }
# ]

# D1 Database
[[d1_databases]]
binding = "DB"
database_name = "CHANGE-ME-d1-name"
# database_id = "CHANGE-ME"   # Add after `wrangler d1 create ...`

# R2 buckets
[[r2_buckets]]
binding = "PRODUCT_MEDIA"
bucket_name = "CHANGE-ME-product-media"

[[r2_buckets]]
binding = "R2_BUCKET"
bucket_name = "CHANGE-ME-temp-uploads"

# Cron triggers
[triggers]
# - */5 keeps the worker warm + reduces cold starts
# - 0 2 runs daily cleanup tasks
crons = ["*/5 * * * *", "0 2 * * *"]

# Non-secret variables
[vars]
VERSION = "1"

# Secrets (set with `wrangler secret put`)
# - ADMIN_SESSION_SECRET
# - ARCHIVE_ACCESS_KEY
# - ARCHIVE_SECRET_KEY
# - TURNSTILE_SECRET_KEY (optional)
# - WHOP_API_KEY (if using Whop)
# - BREVO_API_KEY, BREVO_FROM_EMAIL, BREVO_FROM_NAME (if using Brevo emails)
# - ORDER_ADMIN_EMAIL (optional)
